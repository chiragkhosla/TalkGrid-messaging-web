{
  "name": "whatsapp-like-chat",
  "version": "1.0.0",
  "description": "Full-stack WhatsApp-like chat application",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "socket.io": "^4.8.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
